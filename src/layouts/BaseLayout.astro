---
import "../styles/reset.scss";
import "../styles/design-tokens.scss";
import "../styles/components.scss";
import Header from "../components/Header.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Footer from "../components/Footer.astro";

const siteName = "Dig&Build";
const defaultDescription = "Dig&Buildは、都市の意図を掘り下げるメディアです。建築・再開発・街並みの背景にある思想や物語を読み解きます。";
const {
  title = siteName,
  description = defaultDescription,
  ogType = "website",
  ogImage = "/ogp.webp",
  ogImageAlt = "Dig&Build",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://dig-and-build.com");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

const googleTagManagerScript = `
<script async src="https://www.googletagmanager.com/gtag/js?id=G-QWRQ17Y1KS"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-QWRQ17Y1KS');
</script>`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <Fragment set:html={googleTagManagerScript} />
    {
      googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={googleSiteVerification}
        />
      )
    }
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
  </head>

  <body>
    <Header />
    <main>
      <slot />
    </main>
    <ContactCTA />
    <Footer />
  </body>
</html>

<style lang="scss" is:global>
  @use "../styles/design-tokens.scss" as *;

  body {
    font-family: $font-serif;
    font-size: $fs-body;
    line-height: $lh-body;
    letter-spacing: $tracking;
    color: $fg-1;
    background-color: $color-bg;
    background-image: $paper-noise;
    background-size: $paper-noise-size;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizelegibility;
  }
</style>
