---
import type { GetStaticPaths } from "astro";
import { client } from "../../../lib/microcms";
import type {
  Article,
  Area,
  Category,
  ListResponse,
  Prefecture,
} from "../../../lib/microcms";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageTitle from "../../../components/PageTitle.astro";
import ArticleGrid from "../../../components/ArticleGrid.astro";
import SidebarCategoryList from "../../../components/SidebarCategoryList.astro";
import SidebarAreaList from "../../../components/SidebarAreaList.astro";
import Pagination from "../../../components/Pagination.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const cats = await client.get<ListResponse<Category>>({
    endpoint: "categories",
    queries: { orders: "order", limit: 100 },
  });

  const paths = await Promise.all(
    cats.contents.map(async (cat) => {
      const res = await client.get<ListResponse<Article>>({
        endpoint: "articles",
        queries: {
          filters: `category[equals]${cat.id}`,
          orders: "-publishedAt",
          limit: 100,
          depth: 2,
        },
      });
      return paginate(res.contents, {
        params: { category: cat.slug },
        props: { categoryName: cat.name },
        pageSize: 18,
      });
    }),
  );
  return paths.flat();
}) satisfies GetStaticPaths;

const { page, categoryName } = Astro.props as {
  page: import("astro").Page<Article>;
  categoryName: string;
};
const { category } = Astro.params;

const categories = await client.get<ListResponse<Category>>({
  endpoint: "categories",
  queries: { orders: "order", limit: 100 },
});

const prefectures = await client.get<ListResponse<Prefecture>>({
  endpoint: "prefectures",
  queries: { orders: "order", limit: 100 },
});

const areas = await client.get<ListResponse<Area>>({
  endpoint: "areas",
  queries: { orders: "order", limit: 100 },
});

const hasSidebar =
  categories.contents.length > 0 ||
  (prefectures.contents.length > 0 && areas.contents.length > 0);
const hasMain = page.data.length > 0;

const hrefBuilder = (n: number) =>
  n === 1 ? `/categories/${category}` : `/categories/${category}/${n}`;
---

<BaseLayout title={`カテゴリ/${categoryName} | Dig and Build`}>
  <div class="home-layout">
    {
      hasSidebar && (
        <aside class="home-layout__sidebar">
          {categories.contents.length > 0 && (
            <SidebarCategoryList categories={categories.contents} />
          )}
          {prefectures.contents.length > 0 && areas.contents.length > 0 && (
            <SidebarAreaList
              prefectures={prefectures.contents}
              areas={areas.contents}
            />
          )}
        </aside>
      )
    }
    <div class="home-layout__main">
      <PageTitle prefix="カテゴリ" name={categoryName} />
      {
        hasMain ? (
          <ArticleGrid articles={page.data} />
        ) : (
          <p class="articles-list__empty">記事はまだありません。</p>
        )
      }
      {page.lastPage > 1 && <Pagination page={page} hrefBuilder={hrefBuilder} />}
    </div>
  </div>
</BaseLayout>

<style lang="scss">
  @use "../../../styles/design-tokens.scss" as *;

  .articles-list__empty {
    margin: 0;
    padding: $space-7 0;
    text-align: center;
    color: $color-muted;
    font-family: $font-serif;
  }
</style>
