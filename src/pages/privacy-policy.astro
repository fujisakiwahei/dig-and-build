---
import BaseLayout from "../layouts/BaseLayout.astro";

const policyItems = [
  {
    title: "個人情報の取得について",
    body: [
      "当サイトでは、お問い合わせ、取材依頼、広告掲載のご相談などの際に、氏名、メールアドレス、所属、問い合わせ内容などの個人情報を取得する場合があります。",
      "取得する情報は、利用目的の達成に必要な範囲に限り、適正な方法で取り扱います。",
    ],
  },
  {
    title: "個人情報の利用目的",
    body: [
      "取得した個人情報は、お問い合わせへの回答、取材・広告掲載に関する連絡、当サイトの運営改善、必要な確認連絡のために利用します。",
      "法令に基づく場合を除き、本人の同意なく上記以外の目的で利用することはありません。",
    ],
  },
  {
    title: "第三者提供について",
    body: [
      "当サイトは、法令に基づく場合、本人の同意がある場合、または人の生命・身体・財産の保護に必要な場合を除き、個人情報を第三者に提供しません。",
      "業務上必要な範囲で外部サービスを利用する場合は、適切な管理のもとで取り扱います。",
    ],
  },
  {
    title: "Cookie とアクセス解析について",
    body: [
      "当サイトでは、利便性の向上、閲覧状況の把握、コンテンツ改善のために Cookie やアクセス解析ツールを利用する場合があります。",
      "Cookie によって取得される情報には、特定の個人を直接識別できる情報は含まれません。ブラウザの設定により Cookie を無効にすることができます。",
    ],
  },
  {
    title: "広告配信について",
    body: [
      "当サイトでは、広告配信サービスを利用する場合があります。広告配信事業者は、利用者の興味に応じた広告を表示するために Cookie 等を使用することがあります。",
      "広告配信に関する設定やオプトアウトは、各広告配信事業者が提供する案内をご確認ください。",
    ],
  },
  {
    title: "外部リンクについて",
    body: [
      "当サイトには、外部サイトへのリンクが含まれる場合があります。リンク先サイトにおける個人情報の取り扱いについて、当サイトは責任を負いません。",
      "各リンク先のプライバシーポリシーをご確認ください。",
    ],
  },
  {
    title: "開示・訂正・削除等の請求",
    body: [
      "本人から個人情報の開示、訂正、利用停止、削除等の請求があった場合、本人確認のうえ、法令に従って適切に対応します。",
      "請求内容によっては、対応に必要な範囲で追加情報の提供をお願いする場合があります。",
    ],
  },
  {
    title: "プライバシーポリシーの変更",
    body: [
      "当サイトは、法令の改正、運営方針の変更、利用サービスの変更などに応じて、本ポリシーを改定することがあります。",
      "重要な変更がある場合は、当サイト上でわかりやすく告知します。",
    ],
  },
  {
    title: "お問い合わせ",
    body: [
      "本ポリシーに関するお問い合わせは、当サイトのお問い合わせフォームよりご連絡ください。",
    ],
  },
];
---

<BaseLayout title="プライバシーポリシー | Dig and Build">
  <article class="policy-page">
    <header class="policy-page__hero">
      <p class="policy-page__eyebrow">Privacy Policy</p>
      <h1 class="policy-page__title">プライバシーポリシー</h1>
      <p class="policy-page__lead">
        Dig and Build は、都市、建築、街の変化を記録するメディアとして、利用者の個人情報を適切に取り扱います。
      </p>
    </header>

    <div class="policy-page__body">
      <p class="policy-page__intro">
        本プライバシーポリシーは、Dig and Build（以下「当サイト」）における個人情報の取得、利用、管理、ならびに Cookie 等の取り扱いについて定めるものです。
      </p>

      <div class="policy-page__separator" aria-hidden="true"></div>

      <div class="policy-page__sections">
        {
          policyItems.map((item) => (
            <section class="policy-section">
              <h2 class="policy-section__title">{item.title}</h2>
              {item.body.map((paragraph) => <p>{paragraph}</p>)}
            </section>
          ))
        }
      </div>

      <footer class="policy-page__footer">
        <p>制定日：2026年4月30日</p>
      </footer>
    </div>
  </article>
</BaseLayout>

<style lang="scss">
  @use "../styles/design-tokens.scss" as *;

  .policy-page {
    color: $color-text;
  }

  .policy-page__hero {
    margin: 0 auto;
    padding: clamp(72px, 10vw, 136px) $gutter $space-7;
    max-width: $content-max;
  }

  .policy-page__eyebrow {
    margin: 0 0 $space-3;
    font-family: $font-display;
    font-size: 0.86rem;
    font-weight: 500;
    line-height: $lh-ui;
    letter-spacing: 0.2em;
    color: $color-muted;
  }

  .policy-page__title {
    margin: 0;
    font-family: $font-serif;
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 500;
    line-height: 1.28;
    letter-spacing: $tracking;
    color: $color-engi;
  }

  .policy-page__lead {
    margin: $space-5 0 0;
    font-family: $font-serif;
    font-size: clamp(1.08rem, 1.5vw, 20px);
    font-weight: 600;
    line-height: 1.95;
    letter-spacing: 0.04em;
    color: $color-accent;
  }

  .policy-page__body {
    margin: 0 auto;
    padding: 0 $gutter $space-10;
    max-width: $content-max;
  }

  .policy-page__intro {
    margin: 0 0 $space-4;
    font-family: $font-serif;
    font-size: clamp(1rem, 1.1vw, 1.06rem);
    line-height: 2;
    letter-spacing: 0.04em;
    color: $color-text;
  }

  .policy-page__separator {
    margin: 0 0 $space-7;
    width: 200px;
    height: 1px;
    background-color: $color-engi;
  }

  .policy-page__sections {
    display: grid;
    gap: $space-7;
  }

  .policy-section {
    padding-top: $space-5;
    border-top: 1px solid $color-border;
  }

  .policy-section__title {
    margin: 0 0 $space-4;
    font-family: $font-serif;
    font-size: clamp(1.22rem, 1.55vw, 1.5rem);
    font-weight: 500;
    line-height: 1.55;
    letter-spacing: 0.05em;
    color: $color-accent;
  }

  .policy-section p {
    margin: 0 0 $space-4;
    font-family: $font-serif;
    font-size: clamp(1rem, 1.1vw, 1.06rem);
    line-height: 2;
    letter-spacing: 0.04em;
    color: $color-text;

    &:last-child {
      margin-bottom: 0;
    }
  }

  .policy-page__footer {
    margin-top: $space-8;
    padding-top: $space-5;
    border-top: 1px solid $color-border;
  }

  .policy-page__footer p {
    margin: 0;
    font-family: $font-sans;
    font-size: $fs-meta;
    line-height: $lh-ui;
    letter-spacing: 0.08em;
    color: $color-muted;
  }

  @media (width <= 768px) {
    .policy-page__hero {
      padding-top: $space-8;
    }

    .policy-page__title {
      font-size: clamp(1.8rem, 8vw, 2.5rem);
      line-height: 1.34;
    }

    .policy-page__body {
      padding-bottom: $space-8;
    }

    .policy-page__lead,
    .policy-page__intro,
    .policy-section p {
      line-height: 1.9;
    }

  }
</style>
