---
import type { GetStaticPaths } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { MICROCMS_IMAGE_QUALITY, buildMicroCMSImageSrcSet, buildMicroCMSImageUrl, client, formatDate } from "@/lib/microcms";
import type { Article, ListResponse } from "@/lib/microcms";
import facebookIcon from "@/images/icons/icon-facebook.svg?raw";
import xIcon from "@/images/icons/icon-x.svg?raw";

export const getStaticPaths = (async () => {
  const res = await client.get<ListResponse<Article>>({
    endpoint: "articles",
    queries: {
      orders: "-publishedAt",
      limit: 100,
      depth: 2,
    },
  });

  return res.contents.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}) satisfies GetStaticPaths;

interface Props {
  article: Article;
}

const { article } = Astro.props;
const category = article.category;
const areaLinks: { href: string; name: string; prefectureName: string }[] = [];

for (const articleArea of article.area ?? []) {
  const articlePrefecture = articleArea.prefecture?.[0];

  if (!articlePrefecture) {
    continue;
  }

  areaLinks.push({
    href: `/areas/${articlePrefecture.slug}/${articleArea.slug}/`,
    name: articleArea.name,
    prefectureName: articlePrefecture.name,
  });
}

const articlePath = `/articles/${article.slug}/`;
const canonicalUrl = Astro.site ? new URL(articlePath, Astro.site).toString() : articlePath;
const encodedUrl = encodeURIComponent(canonicalUrl);
const encodedTitle = encodeURIComponent(article.title);
const pageTitle = `${article.title} | Dig&Build`;
const detailImageWidths = [400, 768, 1024, 1536];
const detailImageSizes = "(max-width: 1024px) 100vw, 1024px";
const detailEyecatchImage = article.eyecatch
  ? {
      src: buildMicroCMSImageUrl(article.eyecatch.url, {
        width: 1024,
        fit: "max",
        format: "webp",
        quality: MICROCMS_IMAGE_QUALITY.detail,
      }),
      srcset: buildMicroCMSImageSrcSet(article.eyecatch.url, detailImageWidths, {
        fit: "max",
        format: "webp",
        quality: MICROCMS_IMAGE_QUALITY.detail,
      }),
      ogImage: buildMicroCMSImageUrl(article.eyecatch.url, {
        width: 1200,
        height: 630,
        fit: "crop",
        format: "webp",
        quality: MICROCMS_IMAGE_QUALITY.detail,
      }),
    }
  : undefined;
---

<BaseLayout title={pageTitle} description={article.description} ogType="article" ogImage={detailEyecatchImage?.ogImage}>
  <article class="article-detail">
    <div class="article-detail__layout">
      <div class="article-detail__main">
        <section class:list={["article-hero", { "article-hero--has-eyecatch": article.eyecatch }]}>
          <div class="article-hero__inner">
            <h1 class="article-hero__title">{article.title}</h1>
          </div>
        </section>

        <div class="article-detail__inner">
          {
            article.eyecatch && detailEyecatchImage && (
              <figure class="article-detail__eyecatch">
                <img src={detailEyecatchImage.src} srcset={detailEyecatchImage.srcset} sizes={detailImageSizes} alt="" loading="eager" decoding="async" width={article.eyecatch.width} height={article.eyecatch.height} />
              </figure>
            )
          }

          <div class="article-detail__meta" aria-label="記事情報">
            <div class="article-detail__terms">
              {
                areaLinks.map((areaLink) => (
                  <a class="article-detail__term" href={areaLink.href}>
                    <span class="article-detail__term-prefix">{areaLink.prefectureName} /</span>
                    <span class="article-detail__term-name">{areaLink.name}</span>
                  </a>
                ))
              }
              {
                category && (
                  <a class="article-detail__term" href={`/categories/${category.slug}/`}>
                    {category.name}
                  </a>
                )
              }
            </div>
            <time class="article-detail__date" datetime={article.publishedAt}>
              {formatDate(article.publishedAt)}
            </time>
          </div>

          {article.description && <p class="article-detail__description">{article.description}</p>}
          {article.description && <div class="article-detail__separator" aria-hidden="true" />}

          <div class="article-content" set:html={article.body} />
        </div>
      </div>

      <aside class="article-detail__sidebar" aria-label="記事の共有とナビゲーション">
        <section class="article-share" aria-labelledby="article-share-title">
          <h2 id="article-share-title" class="article-share__title">Share</h2>
          <div class="article-share__buttons" data-article-share>
            <button class="article-share__button" type="button" data-share-copy> リンクをコピー </button>
            <a class="article-share__button article-share__button--icon" href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer" aria-label="Xでシェア" data-share-x>
              <Fragment set:html={xIcon} />
            </a>
            <a class="article-share__button article-share__button--icon" href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Facebookでシェア" data-share-facebook>
              <Fragment set:html={facebookIcon} />
            </a>
          </div>
          <p class="article-share__status" aria-live="polite" data-share-status></p>
        </section>

        <nav class="article-detail__nav" aria-label="記事ナビゲーション">
          <a class="article-detail__nav-link" href="/articles/">記事一覧に戻る</a>
          {
            (category || areaLinks.length > 0) && (
              <ul class="article-detail__nav-secondary">
                {category && (
                  <li>
                    <a
                      class="article-detail__nav-link article-detail__nav-text"
                      href={`/categories/${category.slug}/`}
                    >
                      「{category.name}」の記事一覧に戻る
                    </a>
                  </li>
                )}
                {areaLinks.map((areaLink) => (
                  <li>
                    <a
                      class="article-detail__nav-link article-detail__nav-text"
                      href={areaLink.href}
                    >
                      「{areaLink.name}」の記事一覧に戻る
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </nav>
      </aside>
    </div>
  </article>
</BaseLayout>

<script>
  function initShare() {
    const shareRoot = document.querySelector("[data-article-share]");
    const status = document.querySelector("[data-share-status]");
    const copyButton = document.querySelector("[data-share-copy]");
    const xLink = document.querySelector("[data-share-x]");
    const facebookLink = document.querySelector("[data-share-facebook]");

    if (!shareRoot || !copyButton) return;

    const currentUrl = window.location.href;
    const currentTitle = document.title.replace(" | Dig&Build", "");

    xLink?.setAttribute(
      "href",
      `https://twitter.com/intent/tweet?url=${encodeURIComponent(currentUrl)}&text=${encodeURIComponent(currentTitle)}`,
    );
    facebookLink?.setAttribute(
      "href",
      `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentUrl)}`,
    );

    copyButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(currentUrl);
        if (status) {
          status.textContent = "リンクをコピーしました。";
        }
      } catch {
        if (status) {
          status.textContent = "コピーできませんでした。URLを選択してコピーしてください。";
        }
      }
    });
  }

  document.addEventListener("astro:page-load", initShare);
</script>

<style lang="scss">
  @use "@/styles/design-tokens.scss" as *;

  .article-detail {
    color: $color-text;
  }

  .article-detail__layout {
    margin: 0 auto;
    padding: 0 $gutter $space-10;
    max-width: $content-max;
  }

  .article-detail__main {
    min-width: 0;
  }

  .article-hero {
    padding: 60px 0 clamp(72px, 9vw, 132px);
    background-color: transparent;
  }

  .article-hero--has-eyecatch {
    padding-bottom: clamp(32px, 5vw, 48px);
  }

  .article-hero__inner {
    margin: 0 auto;
    max-width: $content-max;
  }

  .article-hero__title {
    margin: 0;
    font-family: $font-serif;
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 500;
    line-height: 1.5;
    text-align: center;
    color: $color-engi;
  }

  .article-detail__inner {
    margin: 0 auto;
    padding: 0;
    max-width: $content-max;
  }

  .article-detail__eyecatch {
    margin: 0 0 $space-7;
  }

  .article-detail__eyecatch img {
    width: 100%;
    height: auto;
    display: block;
    background-color: $color-bg-deep;
  }

  .article-detail__meta {
    margin-bottom: $space-5;
    display: flex;
    flex-direction: column;
    gap: $space-3;
  }

  .article-detail__terms {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: $space-2;
  }

  .article-detail__term {
    padding: 5px 12px;
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    font-family: $font-serif;
    font-size: $fs-meta;
    line-height: $lh-ui;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: $color-engi-ink;
    background-color: $color-engi;
    transition:
      background-color $dur-2 $ease,
      border-radius $dur-2 $ease;

    &:hover {
      background-color: $color-engi-deep;
      border-radius: 18px;
    }
  }

  .article-detail__term-prefix {
    font-size: 0.78em;
    letter-spacing: 0.08em;
    opacity: 0.72;
  }

  .article-detail__term-name {
    font-size: 1em;
  }

  .article-detail__date {
    font-family: $font-sans;
    font-size: $fs-meta;
    line-height: $lh-ui;
    letter-spacing: 0.1em;
    color: $color-muted;
  }

  .article-detail__description {
    margin: 0 0 $space-4;
    font-family: $font-serif;
    font-size: clamp(1.08rem, 1.5vw, 20px);
    font-weight: 600;
    line-height: 1.95;
    letter-spacing: 0.04em;
    color: $color-accent;
  }

  .article-detail__separator {
    margin: 0 0 $space-7;
    width: 200px;
    height: 1px;
    background-color: $color-engi;
  }

  .article-content {
    font-family: $font-serif;
    font-size: clamp(1rem, 1.1vw, 1.06rem);
    line-height: 2;
    letter-spacing: 0.04em;
    color: $color-text;
  }

  .article-content :global(*) {
    max-width: 100%;
  }

  .article-content :global(*:first-child) {
    margin-top: 0;
  }

  .article-content :global(*:last-child) {
    margin-bottom: 0;
  }

  .article-content :global(p) {
    margin: 0 0 $space-5;
  }

  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4) {
    font-family: $font-serif;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: $color-accent;
  }

  .article-content :global(h1) {
    margin: $space-8 0 $space-4;
    font-size: clamp(1.7rem, 2.4vw, 2.3rem);
    line-height: 1.45;
  }

  .article-content :global(h2) {
    margin: $space-8 0 $space-4;
    font-size: clamp(1.5rem, 2vw, 2rem);
    font-weight: 600;
    line-height: 1.5;
    color: $color-engi;
  }

  .article-content :global(h3) {
    margin: $space-7 0 $space-4;
    font-size: clamp(1.22rem, 1.55vw, 1.5rem);
    font-weight: 600;
    line-height: 1.55;
  }

  .article-content :global(h4) {
    margin: $space-6 0 $space-3;
    font-size: 1.08rem;
    font-weight: 600;
    line-height: 1.65;
  }

  .article-content :global(a) {
    text-decoration: none;
    color: $color-engi;
    overflow-wrap: anywhere;
    transition: color $dur-2 $ease;
    text-underline-offset: 0.22em;

    &:hover {
      text-decoration: underline;
      text-decoration-color: $color-engi;
      color: $color-engi-deep;
    }
  }

  .article-content :global(strong) {
    font-weight: 600;
    color: $color-accent;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: $space-5 0;
    padding-left: 1.6em;
    display: grid;
    gap: $space-2;
  }

  .article-content :global(ul) {
    list-style: outside disc;
  }

  .article-content :global(ol) {
    list-style: outside decimal;
  }

  .article-content :global(li) {
    padding-left: 0.2em;
  }

  .article-content :global(blockquote) {
    margin: $space-7 0;
    padding: $space-5 $space-6;
    color: $color-accent;
    background-color: transparent;
    border: 1px solid $color-engi;
  }

  .article-content :global(blockquote p) {
    margin-bottom: $space-4;
  }

  .article-content :global(figure) {
    margin: $space-7 50% $space-7;
    width: min(100vw - 40px, 960px);
    transform: translateX(-50%);
  }

  .article-content :global(img) {
    width: 100%;
    height: auto;
    display: block;
    background-color: $color-bg-deep;
  }

  .article-content :global(figcaption) {
    margin-top: $space-2;
    font-family: $font-sans;
    font-size: $fs-meta;
    line-height: $lh-ui;
    letter-spacing: 0.04em;
    color: $color-muted;
    overflow-wrap: anywhere;
  }

  .article-content :global(hr) {
    margin: $space-8 0;
    border: 0;
    border-top: 1px solid $color-border;
  }

  .article-content :global(table) {
    margin: $space-7 0;
    width: 100%;
    display: block;
    overflow-x: auto;
    font-family: $font-sans;
    font-size: $fs-small;
    line-height: $lh-ui;
    white-space: nowrap;
    border-collapse: collapse;
  }

  .article-content :global(th),
  .article-content :global(td) {
    padding: $space-3 $space-4;
    text-align: left;
    border: 1px solid $color-border;
    vertical-align: top;
  }

  .article-content :global(th) {
    font-weight: 600;
    color: $color-accent;
    background-color: $color-bg-soft;
  }

  .article-content :global(iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border: 0;
  }

  .article-detail__sidebar {
    margin-top: $space-9;
    padding-top: $space-7;
    border-top: 1px solid $color-border;
  }

  .article-share {
    display: grid;
    justify-items: center;
    gap: $space-4;
  }

  .article-share__title {
    margin: 0;
    font-family: $font-display;
    font-size: 0.88rem;
    font-weight: 500;
    line-height: $lh-ui;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: $color-engi;
  }

  .article-share__buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: $space-2;
  }

  .article-share__button {
    padding: 0 $space-5;
    min-width: 48px;
    min-height: 48px;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    font-family: $font-sans;
    font-size: 0.76rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: $color-engi;
    background-color: transparent;
    border: 1px solid rgb(107 31 36 / 28%);
    border-radius: 0;
    transition:
      color $dur-3 $ease,
      background-color $dur-3 $ease,
      border-color $dur-3 $ease,
      border-radius $dur-3 $ease;
    cursor: pointer;

    &:hover {
      color: $color-engi-ink;
      background-color: $color-engi;
      border-color: $color-engi;
      border-radius: 28px;
    }
  }

  .article-share__button--icon {
    padding: 0;
    width: 48px;
  }

  .article-share__button :global(svg) {
    width: 20px;
    height: 20px;
  }

  .article-share__status {
    margin: 0;
    min-height: 1.5em;
    font-family: $font-sans;
    font-size: $fs-meta;
    line-height: $lh-ui;
    text-align: center;
    color: $color-muted;
  }

  .article-detail__nav {
    margin-top: $space-7;
    display: grid;
    gap: $space-3;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .article-detail__nav-link {
    padding: $space-4 $space-5;
    min-height: 56px;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    font-family: $font-serif;
    font-size: $fs-small;
    line-height: $lh-ui;
    letter-spacing: 0.08em;
    text-align: center;
    text-decoration: none;
    color: $color-engi-ink;
    background-color: $color-engi;
    transition:
      background-color $dur-2 $ease,
      border-radius $dur-2 $ease;

    &:hover {
      background-color: $color-engi-deep;
      border-radius: 28px;
    }
  }

  .article-detail__nav-secondary,
  .article-detail__nav-secondary > li {
    display: contents;
  }

  .article-detail__nav-secondary {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (width >= 1024px) {
    .article-detail__layout {
      max-width: $content-wider;
      display: grid;
      justify-content: center;
      column-gap: clamp(28px, 4vw, 56px);
      grid-template-columns: minmax(0, $content-max) 1px minmax(220px, 280px);

      &::before {
        content: "";
        position: sticky;
        top: 120px;
        margin-top: 60px;
        width: 1px;
        height: 50vh;
        min-height: 280px;
        max-height: 520px;
        align-self: start;
        grid-column: 2;
        grid-row: 1;
        background-color: $color-engi;
        opacity: 0.55;
      }
    }

    .article-detail__main {
      grid-column: 1;
      grid-row: 1;
    }

    .article-detail__sidebar {
      position: sticky;
      top: 120px;
      margin-top: 60px;
      padding-top: 0;
      align-self: start;
      grid-column: 3;
      grid-row: 1;
      border-top: 0;
    }

    .article-share {
      justify-items: stretch;
    }

    .article-share__title {
      text-align: center;
    }

    .article-share__buttons {
      width: 100%;
      display: grid;
      gap: $space-2;
      grid-template-columns: 1fr 1fr;
    }

    .article-share__button {
      width: 100%;
      min-height: 56px;
    }

    [data-share-copy] {
      grid-column: 1 / -1;
    }

    .article-share__button--icon {
      width: 100%;
    }

    .article-detail__nav {
      margin-top: $space-6;
      grid-template-columns: 1fr;
    }

    .article-detail__nav-secondary {
      margin-top: $space-4;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .article-detail__nav-secondary > li {
      display: list-item;
    }

    .article-detail__nav-link.article-detail__nav-text {
      padding: 0;
      min-height: 0;
      justify-content: flex-start;
      gap: 0.5em;
      letter-spacing: 0.06em;
      text-align: left;
      color: $color-engi;
      background-color: transparent;
      border-radius: 0;
      transition:
        color $dur-2 $ease,
        text-decoration-color $dur-2 $ease;
      text-underline-offset: 0.25em;

      &::before {
        content: "←";
        display: inline-block;
        transition: transform $dur-2 $ease;
      }

      &:hover {
        text-decoration: underline;
        color: $color-engi-deep;
        background-color: transparent;
        border-radius: 0;
        text-decoration-thickness: 1px;

        &::before {
          transform: translateX(-2px);
        }
      }
    }

    .article-content :global(figure) {
      margin: $space-7 0;
      width: 100%;
      transform: none;
    }
  }

  @media (width <= 768px) {
    .article-hero {
      padding-top: 40px;
      padding-bottom: 40px;
    }

    .article-hero__title {
      font-size: clamp(1.8rem, 8vw, 2.5rem);
      line-height: 1.34;
    }

    .article-detail__layout {
      padding-bottom: $space-8;
    }

    .article-detail__description,
    .article-content {
      line-height: 1.9;
    }

    .article-content :global(figure) {
      width: calc(100vw - 32px);
    }

    .article-content :global(blockquote) {
      padding: $space-5;
    }

    .article-detail__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
