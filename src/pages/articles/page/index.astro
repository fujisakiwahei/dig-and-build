---
import { client } from "../../../lib/microcms";
import type { Article, ListResponse } from "../../../lib/microcms";
import ArticleArchivePage from "../../../components/ArticleArchivePage.astro";

const PAGE_SIZE = 18;

const res = await client.get<ListResponse<Article>>({
  endpoint: "articles",
  queries: {
    orders: "-publishedAt",
    limit: 100,
    depth: 2,
  },
});

const articles = res.contents.slice(0, PAGE_SIZE);
const lastPage = Math.max(1, Math.ceil(res.contents.length / PAGE_SIZE));
---

<ArticleArchivePage articles={articles} currentPage={1} lastPage={lastPage} />
