---
import { MICROCMS_IMAGE_QUALITY, buildMicroCMSImageSrcSet, buildMicroCMSImageUrl } from "../lib/microcms";
import type { Article } from "../lib/microcms";
import ArticleMeta from "./ArticleMeta.astro";

interface Props {
  article: Article;
}

const { article } = Astro.props;
const href = `/articles/${article.slug}/`;

const excerptMax = 60;
const excerpt = article.description && (article.description.length > excerptMax ? `${article.description.slice(0, excerptMax)}...` : article.description);
const imageWidths = [400, 768, 1024, 1536];
const imageSizes = "(max-width: 768px) 100vw, 50vw";
const imageAspectRatio = { width: 4, height: 3 };
const eyecatchImage = article.eyecatch
  ? {
      src: buildMicroCMSImageUrl(article.eyecatch.url, {
        width: 1024,
        height: Math.round((1024 * imageAspectRatio.height) / imageAspectRatio.width),
        fit: "crop",
        format: "webp",
        quality: MICROCMS_IMAGE_QUALITY.list,
      }),
      srcset: buildMicroCMSImageSrcSet(article.eyecatch.url, imageWidths, {
        fit: "crop",
        format: "webp",
        quality: MICROCMS_IMAGE_QUALITY.list,
        aspectRatio: imageAspectRatio,
      }),
    }
  : undefined;
---

<section class="featured-article">
  <div class="featured-article__inner">
    <h2 class="featured-article__label">【 注目の記事 】</h2>

    <a class="featured-article__link" href={href}>
      <div class="featured-article__thumb">
        {article.eyecatch && eyecatchImage ? <img src={eyecatchImage.src} srcset={eyecatchImage.srcset} sizes={imageSizes} alt="" loading="eager" decoding="async" width={article.eyecatch.width} height={article.eyecatch.height} /> : <div class="featured-article__thumb-placeholder" aria-hidden="true" />}
      </div>

      <div class="featured-article__body">
        <ArticleMeta article={article} />
        <h3 class="featured-article__title">{article.title}</h3>
        {excerpt && <p class="featured-article__excerpt">{excerpt}</p>}
        <span class="featured-article__more">記事を読む →</span>
      </div>
    </a>
  </div>
</section>

<style lang="scss">
  @use "../styles/design-tokens.scss" as *;

  .featured-article {
    width: 100%;

    @media (hover: hover) {
      &:hover {
        .featured-article__thumb {
          border-radius: 0 20px 20px;

          img {
            transform: scale(1.1);
          }
        }

        .featured-article__more {
          border-color: $color-engi;
        }

        .featured-article__title {
          color: $color-engi;
        }
      }
    }
  }

  .featured-article__inner {
    margin: 0 auto;
    padding: $space-7 $gutter $space-6;
    max-width: $content-wider;
  }

  .featured-article__label {
    margin-bottom: $space-6;
    font-family: $font-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: $color-engi;
  }

  .featured-article__link {
    display: grid;
    align-items: center;
    gap: 56px;
    grid-template-columns: 1fr 1fr;
    text-decoration: none;
    color: inherit;
  }

  .featured-article__thumb {
    overflow: hidden;
    background-color: $color-bg-deep;
    border: 1px solid $color-border;
    transition: all $dur-3 $ease;
    aspect-ratio: 4 / 3;

    img {
      width: 100%;
      height: 100%;
      display: block;
      transition: all $dur-1000 $ease;
      object-fit: cover;
    }
  }

  .featured-article__thumb-placeholder {
    width: 100%;
    height: 100%;
    background-color: $color-bg-deep;
  }

  .featured-article__title {
    margin: 16px 0 18px;
    font-family: $font-serif;
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 500;
    line-height: 1.3;
    letter-spacing: 0.04em;
    color: $color-accent;
    transition: color $dur-2 $ease;
  }

  .featured-article__excerpt {
    margin: 0;
    max-width: 460px;
    font-family: $font-serif;
    font-size: 15px;
    line-height: 1.9;
    letter-spacing: 0.03em;
    color: $color-text;
  }

  .featured-article__more {
    margin-top: 28px;
    padding-bottom: 4px;
    display: inline-block;
    font-family: $font-display;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: $color-text;
    border-bottom: 1px solid $color-accent;
    transition: border-color $dur-1 $ease;
  }

  @media (width <= 768px) {
    .featured-article__inner {
      padding: $space-6 $gutter $space-5;
    }

    .featured-article__link {
      gap: $space-5;
      grid-template-columns: 1fr;
    }
  }
</style>
