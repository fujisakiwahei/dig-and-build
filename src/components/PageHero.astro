---
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  image: ImageMetadata;
  alt?: string;
}

const { title, image, alt = "" } = Astro.props;
---

<section class="page-hero">
  <img src={image.src} alt={alt} class="page-hero__bg" />
  <div class="page-hero__overlay" aria-hidden="true"></div>
  <div class="page-hero__inner">
    <div class="page-hero__plate">
      <h1 class="page-hero__title">{title}</h1>
    </div>
  </div>
</section>

<style lang="scss">
  @use "@/styles/design-tokens.scss" as *;

  .page-hero {
    position: relative;
    width: 100%;
    height: 400px;
    overflow: hidden;
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 18%);
  }

  .page-hero__inner {
    position: relative;
    padding: 0 $gutter;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .page-hero__plate {
    padding: $space-2 $space-4;
    text-align: center;
    background: #fff;
    border-radius: $radius-0;
    box-shadow: $shadow-paper;
  }

  .page-hero__title {
    margin: 0;
    font-family: $font-serif;
    font-size: $fs-h1;
    font-weight: 500;
    line-height: $lh-tight;
    letter-spacing: $tracking;
    text-align: center;
    color: $color-accent;
  }
</style>
