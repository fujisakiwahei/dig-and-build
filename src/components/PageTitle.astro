---
interface Props {
  prefix: string;
  name: string;
}

const { prefix, name } = Astro.props;
---

<h1 class="page-title">
  <span class="page-title__prefix">{prefix}</span>
  <span class="page-title__sep" aria-hidden="true">/</span>
  <span class="page-title__name">{name}</span>
</h1>

<style lang="scss">
  @use "../styles/design-tokens.scss" as *;

  .page-title {
    margin: 0 0 $space-5;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    column-gap: 6px;
    font-family: $font-serif;
    color: $color-accent;
    line-height: $lh-tight;
  }

  .page-title__prefix {
    font-size: $fs-small;
    font-weight: 400;
    color: $color-muted;
    letter-spacing: $tracking-eyebrow;
  }

  .page-title__sep {
    font-size: $fs-small;
    font-weight: 400;
    color: $color-muted;
  }

  .page-title__name {
    font-size: $fs-h1;
    font-weight: 500;
    letter-spacing: $tracking;
  }
</style>
