---
const rows = [
  { href: "/categories/", label: "カテゴリー一覧" },
  { href: "/areas/", label: "エリア一覧" },
  { href: "/privacy-policy/", label: "プライバシーポリシー" },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__rows">
      <ul class="site-footer__list">
        {
          rows.map((row) => (
            <li class="site-footer__row">
              <a class="site-footer__row-link" href={row.href}>
                <span class="site-footer__row-label">{row.label}</span>
                <span class="site-footer__row-arrow" aria-hidden="true">
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="site-footer__copy">© {year} Dig&amp;Build</p>
    </div>

    <a class="site-footer__panel" target="_blank" rel="noopener noreferrer" href="https://docs.google.com/forms/d/1dYl56EHVK--TAY-Zd4GTJ_to_TVBcl3umoJiZbq6xWw/edit?hl=ja">
      <span class="site-footer__panel-vertical">問い合わせる</span>
      <span class="site-footer__panel-foot">
        <span class="site-footer__panel-desc"> 取材のご依頼、特集タイアップのご相談、 広告掲載のお問い合わせはこちらから。</span>
        <span class="site-footer__panel-circle" aria-hidden="true">
          <svg width="36" height="14" viewBox="0 0 36 14" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="square">
            <line x1="0" y1="7" x2="34" y2="7"></line>
            <polyline points="28,1 34,7 28,13"></polyline>
          </svg>
        </span>
      </span>
    </a>
  </div>
</footer>

<style lang="scss">
  @use "@/styles/design-tokens.scss" as *;

  .site-footer {
    position: relative;
    padding: 64px $gutter 40px;
    overflow: hidden;
    color: $color-engi-ink;
    background-color: $color-engi-footer;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: radial-gradient(rgb(245 238 230 / 4%) 0.6px, transparent 0.6px);
      background-size: $paper-noise-size;
      pointer-events: none;
    }
  }

  .site-footer__inner {
    position: relative;
    z-index: 1;
    margin: 0 auto;
    max-width: $content-wide;
    display: grid;
    align-items: stretch;
    gap: $space-8;
    grid-template-columns: 1fr minmax(220px, 280px);
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer__row {
    border-top: 1px solid $color-engi-rule;

    &:first-child {
      border-top: 0;
    }
  }

  .site-footer__row-link {
    padding: 22px $space-1;
    display: flex;
    align-items: center;
    gap: $space-4;
    font-family: $font-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: $color-engi-ink;
    transition: color $dur-1 $ease;

    &:hover {
      color: $color-engi-ink-2;
    }
  }

  .site-footer__row-arrow {
    font-size: 14px;
    opacity: 0.7;
  }

  .site-footer__copy {
    padding-top: 18px;
    font-family: $font-display;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: $color-engi-ink-2;
    border-top: 1px solid $color-engi-rule;
  }

  .site-footer__panel {
    padding: 36px 28px;
    min-height: 460px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: $space-6;
    text-decoration: none;
    color: $color-engi-ink;
    border: 1px solid $color-engi-rule;
    transition: background-color $dur-1 $ease;

    &:hover {
      background-color: $color-engi;

      .site-footer__panel-circle {
        background-color: #fff;

        svg {
          color: $color-engi;
        }
      }
    }
  }

  .site-footer__panel-vertical {
    font-family: $font-serif;
    font-size: 38px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.3em;
    color: $color-engi-ink;
    writing-mode: vertical-rl;
  }

  .site-footer__panel-foot {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .site-footer__panel-desc {
    margin-bottom: 28px;
    display: block;
    font-family: $font-serif;
    font-size: 13.5px;
    line-height: 1.85;
    letter-spacing: 0.04em;
    text-align: center;
    color: $color-engi-ink-2;
  }

  .site-footer__panel-circle {
    width: 96px;
    height: 96px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: $color-engi-ink;
    border: 1px solid $color-engi-ink-2;
    border-radius: 50%;
    transition: background-color $dur-1 $ease;
  }

  @media (width <= 768px) {
    .site-footer {
      padding: 48px $gutter 32px;
    }

    .site-footer__inner {
      gap: $space-6;
      grid-template-columns: 1fr;
    }

    .site-footer__panel {
      padding: 28px 24px;
      min-height: 0;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .site-footer__panel-vertical {
      align-self: center;
      font-size: 26px;
      line-height: 1.2;
      letter-spacing: 0.08em;
      white-space: nowrap;
      writing-mode: horizontal-tb;
    }

    .site-footer__panel-desc {
      display: none;
    }

    .site-footer__panel-circle {
      width: 72px;
      height: 72px;
    }
  }
</style>
