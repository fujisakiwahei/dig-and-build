---
const rows = [
  { href: "/categories/", label: "カテゴリー" },
  { href: "/areas/", label: "エリア" },
  { href: "/advertise/", label: "広告掲載・タイアップ" },
  { href: "/privacy-policy/", label: "プライバシーポリシー" },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__rows">
      <ul class="site-footer__list">
        {
          rows.map((row) => (
            <li class="site-footer__row">
              <a class="site-footer__row-link" href={row.href}>
                <span class="site-footer__row-label">{row.label}</span>
                <span class="site-footer__row-arrow" aria-hidden="true">
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="site-footer__copy">© {year} DIG &amp; BUILD</p>
    </div>

    <a class="site-footer__panel" href="/contact/">
      <span class="site-footer__panel-vertical">お問い合わせ</span>
      <span class="site-footer__panel-foot">
        <span class="site-footer__panel-desc">
          取材のご依頼、特集タイアップのご相談、
          広告掲載のお問い合わせはこちらから。
        </span>
        <span class="site-footer__panel-circle" aria-hidden="true">
          <svg
            width="36"
            height="14"
            viewBox="0 0 36 14"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            stroke-linecap="square"
          >
            <line x1="0" y1="7" x2="34" y2="7"></line>
            <polyline points="28,1 34,7 28,13"></polyline>
          </svg>
        </span>
      </span>
    </a>
  </div>
</footer>

<style lang="scss">
  @use "../styles/design-tokens.scss" as *;

  .site-footer {
    position: relative;
    padding: 64px $gutter 40px;
    background-color: $color-engi-footer;
    color: $color-engi-ink;
    overflow: hidden;

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: radial-gradient(
        rgba(245, 238, 230, 0.04) 0.6px,
        transparent 0.6px
      );
      background-size: $paper-noise-size;
      pointer-events: none;
    }
  }

  .site-footer__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr minmax(220px, 280px);
    gap: $space-8;
    align-items: stretch;
    max-width: $content-wide;
    margin: 0 auto;
  }

  .site-footer__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__row {
    border-top: 1px solid $color-engi-rule;

    &:first-child {
      border-top: 0;
    }
  }

  .site-footer__row-link {
    display: flex;
    align-items: center;
    gap: $space-4;
    padding: 22px $space-1;
    font-family: $font-serif;
    font-size: 15px;
    font-weight: 500;
    color: $color-engi-ink;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: color $dur-1 $ease;

    &:hover {
      color: $color-engi-ink-2;
    }
  }

  .site-footer__row-arrow {
    font-size: 14px;
    opacity: 0.7;
  }

  .site-footer__copy {
    padding-top: 18px;
    font-family: $font-display;
    font-size: 12px;
    color: $color-engi-ink-2;
    letter-spacing: 0.18em;
    border-top: 1px solid $color-engi-rule;
  }

  .site-footer__panel {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 460px;
    padding: 36px 28px;
    color: $color-engi-ink;
    text-decoration: none;
    border: 1px solid $color-engi-rule;
    transition: background-color $dur-1 $ease;

    &:hover {
      background-color: $color-engi-glow;
    }
  }

  .site-footer__panel-vertical {
    align-self: flex-end;
    font-family: $font-serif;
    font-size: 38px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.3em;
    color: $color-engi-ink;
    writing-mode: vertical-rl;
  }

  .site-footer__panel-foot {
    display: block;
  }

  .site-footer__panel-desc {
    display: block;
    margin-bottom: 28px;
    font-family: $font-serif;
    font-size: 13.5px;
    line-height: 1.85;
    color: $color-engi-ink-2;
    letter-spacing: 0.04em;
  }

  .site-footer__panel-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    color: $color-engi-ink;
    border: 1px solid $color-engi-ink-2;
    border-radius: 50%;
  }

  @media (max-width: 768px) {
    .site-footer {
      padding: 48px $gutter 32px;
    }

    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: $space-6;
    }

    .site-footer__panel {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      min-height: 0;
      padding: 28px 24px;
    }

    .site-footer__panel-vertical {
      align-self: center;
      font-size: 26px;
      writing-mode: horizontal-tb;
    }

    .site-footer__panel-desc {
      display: none;
    }

    .site-footer__panel-circle {
      width: 72px;
      height: 72px;
    }
  }
</style>
