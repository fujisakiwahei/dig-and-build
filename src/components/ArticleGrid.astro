---
import type { Article } from "../lib/microcms";
import ArticleCard from "./ArticleCard.astro";

interface Props {
  articles: Article[];
  heading?: string;
}

const { articles, heading } = Astro.props;
---

{
  articles.length > 0 && (
    <section class="article-grid">
      <div class="article-grid__inner">
        {heading && <h2 class="article-grid__label">【 {heading} 】</h2>}
        <div class="article-grid__grid">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </div>
    </section>
  )
}

<style lang="scss">
  @use "../styles/design-tokens.scss" as *;

  .article-grid {
    width: 100%;
  }

  .article-grid__inner {
    max-width: $content-wide;
    margin: 0 auto;
    padding: $space-6 $gutter;
  }

  .article-grid__label {
    margin-bottom: $space-5;
    font-family: $font-serif;
    font-size: 18px;
    font-weight: 600;
    color: $color-engi;
    letter-spacing: 0.14em;
  }

  .article-grid__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 32px;
  }

  @media (max-width: 1024px) {
    .article-grid__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 24px;
    }
  }

  @media (max-width: 640px) {
    .article-grid__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
