---
import type { Article } from "@/lib/microcms";
import ArticleCard from "@/components/ArticleCard.astro";

type HeadingTag = "h1" | "h2";

interface Props {
  articles: Article[];
  heading?: string;
  headingTag?: HeadingTag;
}

const { articles, heading, headingTag = "h2" } = Astro.props;
const HeadingElement = headingTag;
---

{
  articles.length > 0 && (
    <section class="article-grid">
      <div class="article-grid__inner">
        {heading && <HeadingElement class="article-grid__label">【 {heading} 】</HeadingElement>}
        <div class="article-grid__grid">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </div>
    </section>
  )
}

<style lang="scss">
  @use "@/styles/design-tokens.scss" as *;

  .article-grid {
    width: 100%;
  }

  .article-grid__inner {
    margin: 0 auto;
    padding: $space-6 $gutter;
    max-width: $content-wide;
  }

  .article-grid__label {
    margin-bottom: $space-5;
    font-family: $font-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.14em;
    color: $color-engi;
  }

  .article-grid__grid {
    display: grid;
    gap: 48px 32px;
    grid-template-columns: repeat(3, 1fr);
  }

  @media (width <= 1024px) {
    .article-grid__grid {
      gap: 40px 24px;
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (width <= 640px) {
    .article-grid__grid {
      gap: 32px;
      grid-template-columns: 1fr;
    }
  }
</style>
