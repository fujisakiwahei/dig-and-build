---
const navItems = [
  { href: "/articles/", label: "記事一覧" },
  { href: "/categories/", label: "カテゴリー一覧" },
  { href: "/areas/", label: "エリア一覧" },
  { href: "/about/", label: "このメディアについて" },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="site-header__nav" aria-label="グローバルナビゲーション">
    <a class="site-header__wordmark" href="/" aria-label="Dig & Build トップへ">
      DIG &amp; BUILD
    </a>

    <ul class="site-header__links">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "site-header__link",
                currentPath.startsWith(item.href) && "is-active",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a class="site-header__cta" href="/contact/">問い合わせる</a>
  </nav>
</header>

<style lang="scss">
  @use "../styles/design-tokens.scss" as *;

  .site-header {
    width: 100%;
    background-color: $color-bg;
  }

  .site-header__nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: $space-5;
    max-width: $content-wide;
    margin: 0 auto;
    padding: 28px $gutter 18px;
    border-bottom: 1px solid $color-border;
  }

  .site-header__wordmark {
    flex-shrink: 0;
    font-family: $font-display;
    font-size: 22px;
    font-weight: 400;
    color: $color-accent;
    letter-spacing: 0.22em;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-header__links {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    align-items: baseline;
    margin-left: auto;

    li {
      list-style: none;
    }
  }

  .site-header__link {
    font-family: $font-sans;
    font-size: 12.5px;
    color: $color-text;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: color $dur-1 $ease;

    &:hover,
    &.is-active {
      color: $color-engi;
    }
  }

  .site-header__cta {
    flex-shrink: 0;
    margin-left: $space-2;
    padding: 10px 20px;
    font-family: $font-serif;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.2;
    color: $color-engi-ink;
    background-color: $color-engi;
    border-radius: 0;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition:
      background-color $dur-1 $ease,
      border-radius 300ms ease-in-out,
      box-shadow $dur-1 $ease;

    &:hover {
      background-color: $color-engi-soft;
      border-radius: 20px;
    }

    &:active {
      background-color: $color-engi-deep;
      box-shadow: $shadow-engi-press;
    }
  }

  @media (max-width: 768px) {
    .site-header__nav {
      flex-wrap: wrap;
      row-gap: $space-4;
      padding: 20px $gutter 14px;
    }

    .site-header__links {
      order: 3;
      width: 100%;
      gap: 20px;
      margin-left: 0;
    }

    .site-header__cta {
      margin-left: 0;
      padding: 8px 16px;
      font-size: 12.5px;
    }
  }
</style>
