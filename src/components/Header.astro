---
const navItems = [
  { href: "/articles/page/", label: "記事一覧", activePrefix: "/articles/" },
  { href: "/categories/", label: "カテゴリー一覧", activePrefix: "/categories/" },
  { href: "/areas/", label: "エリア一覧", activePrefix: "/areas/" },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="site-header__nav" aria-label="グローバルナビゲーション">
    <a class="site-header__wordmark" href="/" aria-label="Dig&amp;Build トップへ"> Dig&amp;Build </a>

    <ul class="site-header__links">
      {
        navItems.map((item) => (
          <li>
            <a href={item.href} class:list={["site-header__link", currentPath.startsWith(item.activePrefix) && "is-active"]}>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a class="site-header__cta" target="_blank" rel="noopener noreferrer" href="https://docs.google.com/forms/d/1dYl56EHVK--TAY-Zd4GTJ_to_TVBcl3umoJiZbq6xWw/edit?hl=ja">問い合わせる</a>
  </nav>
</header>

<style lang="scss">
  @use "../styles/design-tokens.scss" as *;

  .site-header {
    position: sticky;
    z-index: 100;
    top: 0;
    width: 100%;
    background-color: $color-bg-soft;
  }

  .site-header__nav {
    padding: 28px $gutter 18px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: $space-5;
    border-bottom: 1px solid $color-border;
  }

  .site-header__wordmark {
    font-family: $font-display;
    font-size: 22px;
    font-weight: 400;
    text-decoration: none;
    white-space: nowrap;
    color: $color-engi;
    flex-shrink: 0;
  }

  .site-header__links {
    margin-left: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 28px;

    li {
      list-style: none;
    }
  }

  .site-header__link {
    font-family: $font-sans;
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: $color-text;
    transition: color $dur-1 $ease;

    &:hover,
    &.is-active {
      color: $color-engi;
    }
  }

  .site-header__cta {
    margin-left: $space-2;
    padding: 10px 20px;
    font-family: $font-serif;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: $color-engi-ink;
    background-color: $color-engi;
    border-radius: 0;
    transition:
      background-color $dur-1 $ease,
      border-radius 300ms ease-in-out,
      box-shadow $dur-1 $ease;
    flex-shrink: 0;

    &:hover {
      background-color: $color-engi-soft;
      border-radius: 20px;
    }

    &:active {
      background-color: $color-engi-deep;
      box-shadow: $shadow-engi-press;
    }
  }

  @media (width <= 768px) {
    .site-header__nav {
      padding: 20px $gutter 14px;
      flex-wrap: wrap;
      row-gap: $space-4;
    }

    .site-header__links {
      margin-left: 0;
      width: 100%;
      gap: 20px;
      order: 3;
    }

    .site-header__cta {
      margin-left: 0;
      padding: 8px 16px;
      font-size: 12.5px;
    }
  }
</style>
